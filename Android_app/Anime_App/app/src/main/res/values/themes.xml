<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AnimeApp" parent="android:Theme.Material.NoActionBar">
        <!-- Window background = M3 dark purple (matches the app theme).
             This prevents the gray #303030 flash before Compose loads. -->
        <item name="android:colorBackground">#14111F</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
